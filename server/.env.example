PORT=5001
# Local AI (Ollama)
OLLAMA_URL=http://localhost:11434/api/generate
AI_MODEL=llama3

# Cloud AI (Groq - required for deployment)
# Get yours at https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# Production Database (for Render persistent disk)
# DATABASE_PATH=/var/data/database.sqlite
# Database will be created automatically in server/data/database.sqlite
